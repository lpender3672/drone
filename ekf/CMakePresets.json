{
    "version": 3,
    "configurePresets": [
        {
            "name": "windows-debug",
            "displayName": "Windows Debug",
            "description": "Debug build with testing for Windows (MinGW64)",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/windows-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "description": "Debug build with testing for Linux",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/linux-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "rpi-debug",
            "displayName": "Raspberry Pi Debug",
            "description": "Debug build with testing for Raspberry Pi",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build/rpi-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTING": "ON"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug"
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "rpi-debug",
            "configurePreset": "rpi-debug"
        }
    ],
    "testPresets": [
        {
            "name": "windows-test",
            "configurePreset": "windows-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-test",
            "configurePreset": "linux-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "rpi-test",
            "configurePreset": "rpi-debug",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}